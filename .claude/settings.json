{
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Bash",
      "PowerShell",
      "Bash(*)",
      "PowerShell(*)",
      "TaskStop",
      "ToolSearch",
      "Bash(cd *)",
      "Bash(echo *)",
      "Bash(export *)",
      "Skill",
      "Agent",
      "Workflow",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(dotnet *)",
      "Bash(ng *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(curl *)",
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(bash *)",
      "PowerShell(git *)",
      "PowerShell(gh *)",
      "PowerShell(dotnet *)",
      "PowerShell(ng *)",
      "PowerShell(npm *)",
      "PowerShell(npx *)",
      "PowerShell(node *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "PowerShell(git push --force*)",
      "PowerShell(git push -f *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-guard.sh\"",
            "timeout": 15,
            "statusMessage": "Git guard: kiểm tra review gate / bảo vệ main"
          }
        ]
      }
    ]
  }
}
